$ Missing = after named identifier
number foo 10;

$ Missing = after decimal
decimal pi 3.14;

$ Expected assignment operator after named variable
foo + 5;

$ Keyword used as statement start
while;

$ Bad expression using boolean operator as value
yesno flag = &;

$ Missing expression after comparison
yesno result = 10 ====;

$ Unexpected ? as statement start
? foo = yes;

$ Missing condition in if
if () {
    write "bad";
}

$ Concat without right hand side
write "hello" #;

$ For loop with missing identifier
for (number = 0; number < 10; number++) {
    write "bad";
}

$ Nested bad assignment
if (yes) {
    decimal pi 3.14;
    foo ~ 5;
}